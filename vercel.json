{
  "version": 3,
  "routes": [
    { "handle": "filesystem" },

    {
      "src": "^/server/(.+)\\.ts$",
      "dest": "/server/$1",
      "check": true
    },

    {
      "src": "^/server(/.*)?$",
      "status": 404
    },

    {
      "src": "/(.*)",
      "dest": "/"
    },

    { "handle": "error" },

    {
      "status": 404,
      "dest": "/404.html"
    }
  ]
}