{
  "name": "honno-react-demo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun ./server/index.ts",
    "dev": "bun run --hot ./server/index.ts",
    "build": "cd frontend && bun install && bun run build",
    "drizzle:push": "bunx drizzle-kit push",
    "drizzle:generate": "bunx drizzle-kit generate",
    "drizzle:migrate": "tsx ./server/db/migrate.ts",
    "drizzle:seed": "tsx ./server/db/seed.ts",
    "drizzle:reset": "tsx ./server/db/reset.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@kinde-oss/kinde-typescript-sdk": "^2.13.2",
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
